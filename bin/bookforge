#!/usr/bin/env sh
set -eu

# The managed PATH entry is a file symlink to this launcher. Resolve it without
# readlink -f, which is unavailable in macOS's BSD readlink.
SOURCE=$0
while [ -h "$SOURCE" ]; do
  DIRECTORY=$(CDPATH= cd -P -- "$(dirname -- "$SOURCE")" && pwd)
  LINK=$(readlink "$SOURCE") || exit 1
  case "$LINK" in
    /*) SOURCE=$LINK ;;
    *) SOURCE=$DIRECTORY/$LINK ;;
  esac
done
ROOT=$(CDPATH= cd -P -- "$(dirname -- "$SOURCE")/.." && pwd)
EXPECTED_NODE="v24.18.0"

if ! NODE_VERSION=$(node --version 2>/dev/null); then
  echo "bookforge: Node.js 24.18.0 is required but node is unavailable" >&2
  exit 1
fi
if [ "$NODE_VERSION" != "$EXPECTED_NODE" ]; then
  echo "bookforge: Node.js 24.18.0 is required; found $NODE_VERSION" >&2
  exit 1
fi

case "${1:-}" in
  update|rollback)
    command=$1
    shift
    exec "$ROOT/installer/manage.sh" "$command" "$@"
    ;;
esac

exec node "$ROOT/lib/cli.js" "$@"
